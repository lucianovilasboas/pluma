DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
FERNET_KEY=change-me-fernet-key
POSTGRES_DB=essay_essay
POSTGRES_USER=essay_essay
POSTGRES_PASSWORD=essay_essay
POSTGRES_HOST=localhost
POSTGRES_PORT=5437
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o
LOG_LEVEL=INFO
# false = avaliação LLM roda inline (dev). Em produção/Docker use true
# para enviar à fila do qcluster e não travar o worker web (WORKER TIMEOUT).
AVALIACAO_USE_Q2=false
# Cookies Secure (só valem em config.settings.production). Deixe "false" ao
# acessar via HTTP puro (docker compose local sem TLS), senão o navegador
# descarta o cookie de sessão e o login não persiste. Use "true" atrás de
# Traefik/HTTPS em produção.
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
